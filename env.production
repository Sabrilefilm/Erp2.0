APP_NAME="Ultra by Unions agency"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://votredomaine.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=erp_tiktok_prod
DB_USERNAME=votre_user_db
DB_PASSWORD=votre_password_db

BROADCAST_CONNECTION=log
CACHE_STORE=redis
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# Génération automatique des questions de quiz (formations)
OPENAI_API_KEY=votre_clé_openai
OPENAI_MODEL=gpt-4o-mini

# Notifications push (Web Push)
WEBPUSH_VAPID_SUBJECT="mailto:admin@votredomaine.com"
WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=

# Cache et optimisation
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@votredomaine.com"
MAIL_FROM_NAME="${APP_NAME}"
