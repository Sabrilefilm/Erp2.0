APP_NAME="Ultra by Unions agency"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=erp_tiktok
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_CONNECTION=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
SESSION_LIFETIME=120

# Génération automatique des questions de quiz (formations)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Notifications push (Web Push) — générer avec: php artisan push:generate-vapid-keys
WEBPUSH_VAPID_SUBJECT="mailto:admin@votredomaine.com"
WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=

# Optionnel : notifications temps réel (Pusher)
# VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_CLUSTER=mt1
